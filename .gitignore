# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Production build
dist/
build/

# Environment variables (exclude all .env files)
.env*

# But allow .env example files (templates for developers)
!.env.example
!.env.email-service.example
!.env.production.template

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs
*.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/

# Dependency directories
jspm_packages/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# next.js build output
.next

# nuxt.js build output
.nuxt

# vuepress build output
.vuepress/dist

# Serverless directories
.serverless

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# ESP32 Device Service Runtime Data
device_data/device-registry.json
device_data/device-commands.json

# Python compiled files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Device client logs
device_client/*.log
device_client/dist/
device_client/build/

# AOD Upload Service (server-side only)
aod-upload-service.cjs
uploads/

# Nginx configuration (server-specific)
nginx-*.conf

# Test files (development and debugging)
test-*.js
test-*.html
test-*.py
test-*.csv
test-*.json

# additional ignores ...to be reviewed 

# Documentation files (if you don't want to track them)
*_COMPLETE.md
*_PLAN.md
*_GUIDE.md
*_ANALYSIS.md
*_IMPLEMENTATION*.md
*_FIX*.md
*_SUMMARY.md

# Deployment scripts (if temporary)
deploy-*.bat
deploy-*.sh
fix-*.bat
fix-*.sh
debug-*.sh
verify-*.sh
restart-*.sh

# Backup/versioned files
*_[0-9][0-9]jan[0-9][0-9][0-9][0-9].*
*_[0-9][0-9]Jan[0-9][0-9][0-9][0-9].*
*_[0-9][0-9]feb[0-9][0-9][0-9][0-9].*
*_[0-9][0-9]Feb[0-9][0-9][0-9][0-9].*
* - Copy.*

# Test files (already covered but being explicit)
test-*.cjs
brevo-*.js
brevo-*.cjs
verify-*.cjs

# Build scripts
build-*.bat
build-*.ps1
start-*.bat

# Logs and transaction files
*.txt
!README.txt

# Temporary vite files
vite.config.js.timestamp-*
